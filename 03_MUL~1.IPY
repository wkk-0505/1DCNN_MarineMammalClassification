   "source": [
    "## Confusion Matrix"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
   "id": "613d9af6-d755-40f7-b13c-f3723a6571f3",
   "metadata": {},
   "outputs": [],
   "source": [
    "def get_predictions_and_labels(ensemble_models, device, loader):\n",
    "    all_preds = []\n",
    "    all_labels = []\n",
    "    with torch.no_grad():\n",
    "        for batch_idx, (data_parts, target) in enumerate(loader):\n",
    "            batch_pred = []\n",
    "            batch_label = []\n",
    "        \n",
    "            target = target.to(device)\n",
    "\n",
    "            for i, sequence_parts in enumerate(data_parts):\n",
    "                sequence_parts = [part.to(device) for part in sequence_parts]\n",
    "\n",
    "                model_votes = []\n",
    "                for model in ensemble_models:\n",
    "                    output = model(sequence_parts)\n",
    "                    pred = output.argmax(dim=0, keepdim=True)\n",
    "                    model_votes.append(pred)\n",
    "                    \n",
    "                most_common_pred = Counter(model_votes).most_common(1)[0][0]\n",
    "                batch_pred.append(most_common_pred.cpu().item())\n",
    "                batch_label.append(target[i].cpu().item())\n",
    "            \n",
    "            all_preds.extend(batch_pred)\n",
    "            all_labels.extend(batch_label)\n",
    "    return all_preds, all_labels"
   ]
  },
